# ============================================================================
# DATABASE
# ============================================================================
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/quikscale_dev
DATABASE_URL="postgresql://user:password@localhost:5432/quikscale_dev"

# ============================================================================
# NEXTAUTH
# ============================================================================
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# OAUTH PROVIDERS (Optional - for future)
# ============================================================================
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_ID=""
GOOGLE_SECRET=""

# ============================================================================
# AI FEATURES (Phase 13)
# ============================================================================
ANTHROPIC_API_KEY=""

# ============================================================================
# EXTERNAL SERVICES (Future)
# ============================================================================
STRIPE_SECRET_KEY=""
SLACK_BOT_TOKEN=""
SENDGRID_API_KEY=""

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL="info"
SENTRY_DSN=""

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_AI_INSIGHTS="false"
FEATURE_POWER_OF_ONE="true"
FEATURE_SLACK_INTEGRATION="false"
